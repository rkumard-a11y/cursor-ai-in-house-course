# --- Dependencies ---
node_modules/

# --- Build & bundler output ---
dist/
build/
out/
.vite/
*.tsbuildinfo

# --- Environment & secrets (never commit real secrets) ---
.env
.env.local
.env.*.local
!.env.example
!**/.env.example

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env.bak/
venv.bak/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# --- Test & coverage ---
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/
pytestdebug.log

# --- Playwright / E2E artifacts ---
playwright-report/
test-results/
blob-report/
playwright/.cache/

# --- Logs & debug ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- OS & editor junk ---
.DS_Store
Thumbs.db
Desktop.ini
.idea/
*.swp
*.swo
*~
*.sublime-*

# --- Local databases (SQLite / dev) ---
*.db
*.sqlite
*.sqlite3

# --- QA automation generated reports (see qa-automation/.gitignore) ---
qa-automation/reports/raw/
qa-automation/reports/dashboard_data.json
qa-automation/reports/RECOMMENDATIONS.md

# --- Misc caches ---
.cache/
*.tmp
.temp/
