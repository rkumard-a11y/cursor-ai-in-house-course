{
  "name": "course-qa-automation",
  "private": true,
  "version": "1.0.0",
  "description": "Jest unit smoke + Lighthouse CI helpers for QA automation",
  "scripts": {
    "test:unit": "jest --config jest.config.cjs",
    "test:unit:cov": "jest --config jest.config.cjs --coverage",
    "lint:qa": "cd .. && eslint -f stylish \"src/**/*.{ts,tsx}\"",
    "lhci": "lhci autorun --config=performance/lighthouse.config.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.14.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
